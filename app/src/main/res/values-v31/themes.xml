<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg_amoled</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_app_logo_anim</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.Snaptick</item>
    </style>

    <style name="Theme.App.Starting.Amoled" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/splash_bg_amoled</item>
    </style>

    <style name="Theme.App.Starting.Dark" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/splash_bg_dark</item>
    </style>

    <style name="Theme.App.Starting.Light" parent="Theme.App.Starting">
        <item name="windowSplashScreenBackground">@color/splash_bg_light</item>
    </style>

</resources>
