<?xml version="1.0" encoding="utf-8"?>
<!--
   Legacy auto-backup rules for API < 31. Same intent as data_extraction_rules.xml:
   keep the user's task DB and DataStore prefs out of the cloud backup.
-->
<full-backup-content>
    <exclude domain="database" path="local_db" />
    <exclude domain="database" path="local_db-shm" />
    <exclude domain="database" path="local_db-wal" />
    <exclude domain="file" path="datastore/" />
    <exclude domain="sharedpref" path="snaptick_splash_prefs.xml" />
</full-backup-content>
